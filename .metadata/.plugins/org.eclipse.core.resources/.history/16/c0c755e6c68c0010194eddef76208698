package com.check;

public class ControlFlowofTryCatch {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		try
		{
			System.out.println("Statement 1: "+10/2);
			System.out.println("Statement 2: "+60/10);
			System.out.println("Statement 3: "+20/0);  
			// if exception raised then after no one Statement 
		    //is execute inside try block
			System.out.println("Statement 4: "+100/10);
			System.out.println("Statement 5: "+5/2);
		}
		catch(Exception e)
		{
			System.out.println("Statement 6: "+20/5);
		}
		System.out.println("Statement 7: "+"End all");
	}

}
