package com.string;

import java.util.Scanner;

public class Q2 {

	public static void main(String[] args) {
		// Find UserName or Domain Name of user
//		ayushbbu37@gmail.com
		
		System.out.println("Inputed Email i'd");
		Scanner sc=new Scanner(System.in);
		String str=sc.next();
		int j=str.indexOf('@');
		System.out.println("User Name = "+str.substring(0, j));
		int k=str.lastIndexOf("com");
		System.out.println("Domain Name = "+str.substring(j+1, k));
	}

}
