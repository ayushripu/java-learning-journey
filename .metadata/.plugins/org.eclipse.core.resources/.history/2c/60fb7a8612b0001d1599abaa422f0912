package com.Array;

import java.util.Scanner;

public class max 
{
	public static void main(String[] args) 
	{
		 int i,n,max=0;
		Scanner sc=new Scanner(System.in);
		System.out.print("Inputed How Much Number Do you Want : ");
		n=sc.nextInt();
		int a[]=new int[n];
		for( i=0;i<a.length;i++)
		{
			a[i]=sc.nextInt();
		}
		for( i=0;i<a.length;i++)
		{
			if(a[i]>=max)
			{
				max=a[i];
			}
		}sc.close();
		System.out.println("Max= "+max);
	}
}
