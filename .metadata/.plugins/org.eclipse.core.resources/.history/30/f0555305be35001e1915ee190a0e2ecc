package com.For;

public class FactorialOf_a_Number {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		int f=1;
		for(int i=1;i<=5;i++)
		{
			System.out.println(i);
			f=f*i;
			System.out.println(f+"*"+i+"=");
		}
		System.out.println("Factorial of Total Number is :"+f);
	}

}
