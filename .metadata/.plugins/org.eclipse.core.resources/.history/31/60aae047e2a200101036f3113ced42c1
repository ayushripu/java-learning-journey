package com.For;

public class Pattern7 {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		for(int i=1;i<=5;i++)
		{
			for(int j=1;j<=5-i;j++)
			{
				System.out.print(" ");
			}
			for(int k=1;k<=i;k++)
			{
				System.out.print("*");
			}
			
			
			for(int l=5;l<=i;l++)
			{
				System.out.print(" ");
			}
			for(int m=1;m<=i;m++)
//			{
				System.out.print("*");
//			}
			System.out.println();
		}
		
		
		
		
		for(int i=5;i>=1;i--)
		{
			for(int j=1;j<=5-i;j++)
			{
				System.out.print(" ");
			}
			for(int k=1;k<=i;k++)
			{
				System.out.print("*");
			}
			System.out.println();
			
			
		}
	}
}