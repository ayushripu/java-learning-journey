package com.currency;

import java.lang.*;
import java.net.HttpURLConnection;
import java.net.URL;
import java.util.Scanner;
import org.json.JSONObject;


public class CurrencyConverter {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);

        System.out.println(" Currency Converter");
        System.out.print("Enter base currency (e.g., USD): ");
        String baseCurrency = scanner.next().toUpperCase();

        System.out.print("Enter target currency (e.g., INR): ");
        String targetCurrency = scanner.next().toUpperCase();

        System.out.print("Enter amount to convert: ");
        double amount = scanner.nextDouble();

        try {
        	String apiKey = "bf212137082a63b47a90e92567a85394"; // Replace with your real key
        	String urlStr = "https://api.apilayer.com/exchangerates_data/convert?from=" + baseCurrency +
        	                "&to=" + targetCurrency +
        	                "&amount=" + amount +
        	                "&access_key=" + apiKey;


            URL url = new URL(urlStr);
            HttpURLConnection conn = (HttpURLConnection) url.openConnection();
            conn.setRequestMethod("GET");
            conn.connect();

            int responseCode = conn.getResponseCode();

            if (responseCode == 200) {
                Scanner urlScanner = new Scanner(url.openStream());
                StringBuilder inline = new StringBuilder();
                while (urlScanner.hasNext()) {
                    inline.append(urlScanner.nextLine());
                }
                urlScanner.close();

                JSONObject data = new JSONObject(inline.toString());
                double result = data.getDouble("result");

                System.out.println(" Converted Amount: " + result + " " + targetCurrency);
            } else {
                System.out.println(" Failed to fetch exchange rate. HTTP Code: " + responseCode);
            }

        } catch (Exception e) {
            System.out.println(" Error: " + e.getMessage());
        }

        scanner.close();
    }
}
