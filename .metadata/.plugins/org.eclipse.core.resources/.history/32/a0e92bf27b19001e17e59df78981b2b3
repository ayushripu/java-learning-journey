package com.string;

public class Format {

	public static void main(String[] args) {
		// TODO Auto-generated method stub

		int a=-10;
		System.out.printf("%(5d\n",a);
		System.out.printf("%5d \n",a);
		System.out.printf("%05d\n",a);
		
		float b=123.45f;
		System.out.printf("\n%.2f\n",b);
		
		String str="Ayush";
		System.out.printf("\n%-20s",str);
//		str.trim();
	}

}
