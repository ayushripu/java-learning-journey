package com.Array;

import java.util.Arrays;
import java.util.Scanner;

public class RandomNo 
{
	public static void main(String[] args) 
	{
		int n=0,min,max;
		Scanner sc=new Scanner (System.in);
		System.out.println("Inputed How Many Random Number : ");
		n=sc.nextInt();
		int a[]=new int[n];
		for(int i=0;i<a.length;i++)
		{
			a[i]=sc.nextInt();
		}
	    min=max=a[0];
		for(int i=0;i<a.length;i++)
		{
			if(a[i]>=max)
			{
				max=a[i];
			}
			if(a[i]<=min)
			{
				min=a[i];
			}
		}
		System.out.printf("Random Value is : ","%.2d",Math.random()*(max-min)+min);
	}
}