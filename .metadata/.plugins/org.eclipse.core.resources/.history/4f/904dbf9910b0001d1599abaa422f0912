package com.Array;

import java.util.Scanner;

public class max 
{
	public static void main(String[] args) 
	{
		int n,max=0;
		Scanner sc=new Scanner(System.in);
		System.out.print("Inputed How Much Number Do you Want : ");
		n=sc.nextInt();
		int a[]=new int[n];

		for(int i=0;i<a.length;i++)
		{
			a[i]=sc.nextInt();
		}
		sc.close();
		for(int i=0;i<a.length;i++)
		{
			max = Math.max(a[i],a[i]);
		}
		System.out.println("Max is : "+max);
	}
}
