package com.Set;
import java.util.*;
public class NavigableSetCheck {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		Scanner sc=new Scanner(System.in);
		TreeSet <Integer> t=new TreeSet<>();
		for(int i=0;i<=4;i++)
		{
			System.out.print("Inputed "+i+" Element: ");
			t.add(sc.nextInt());
		}
		System.out.println(t);
		System.out.println("Floor: "+t.floor(10));
		System.out.println("Lower: "+t.lower(15));
		System.out.println("ceiling: "+t.ceiling(20));
		System.out.println("Heigher: "+t.higher(30));
		System.out.println("PollFirst: "+t.pollFirst());
		System.out.println("PollLast"+ t.pollLast());
		System.out.println("Final Element: "+t);
	}

}
