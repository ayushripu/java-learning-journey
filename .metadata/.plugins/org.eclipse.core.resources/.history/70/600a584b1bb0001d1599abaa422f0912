package com.Array;
import java.util.*;
public class FillMethod
{
	public static void main(String[] args)
	{
		int n=0;
		Scanner sc=new Scanner(System.in);
		System.out.println("Inputed How Many Number : ");
		n=sc.nextInt();
		int a[]=new int[n];
		System.out.println("Empty Array is :-> "+Arrays.toString(a));
		Arrays.fill(a,6);
		a[n]=8;
		System.out.println("Fill Array is :-> "+Arrays.toString(a));
		sc.close();
	}
}