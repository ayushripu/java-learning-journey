package com.Array;

public class Increse {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		int a[]= {3,4,5,2,1};
		int b[]=new int[a.length+10];
		
		for(int i=0;i<b.length;i++)
		{
			b[i]=a[i];
		}
		System.out.println(b.length);
		System.out.println(a.length);
	}

}
