package com.Array;

import java.util.Scanner;

public class TableOfElement 
{
	public static void main(String[] args) 
	{
	int n;
	Scanner sc=new Scanner (System.in);
	System.out.print("How Many Number Do You Want To Print Table : ");
	n=sc.nextInt();
	int a[]=new int[n];
	for(int i=0;i<a.length;i++)
		{
			System.out.print("Inputed "+(i+1)+" Table : ");
			a[i]=sc.nextInt();
		}
		for(int i=0;i<a.length;i++)
		{
			for(int j=1;j<=10;j++)
			{
				System.out.println(a[i]+"*"+j+"="+(a[i]*j));
			}
			System.out.print("");
		}
	}
}
