import java.util.*;
public class doc
{
	public static void main(String[] args)
	{
		int n,even,count=0;
		Scanner sc=new Scanner(System.in);
		System.out.print("Inputed How Many Number ");
		n=sc.nextInt();
		int a[]=new int[n];
		for(int i=0;i<a.length;i++)
		{
			a[i]=sc.nextInt();
		}
		System.out.println("Even number is : ");	
		for(int i=0;i<a.length;i++)
		{
			if(a[i]%2==0)
			{
				count++;
				System.out.println(a[i]+" even");
			}
			else
			{
				System.out.println(a[i]+" Not Even");
			}
		}
		System.out.print("");
		System.out.print("Total Even Number is "+count);
	}
}