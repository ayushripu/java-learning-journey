//Ascii Value of each character array;

import java.util.*;
public class Ascii
{
	public static void main(String[]args)
	{
		Scanner sc=new Scanner(System.in);
		System.out.print("Inputed any Character : ");
		int n=sc.nextInt();
		char a[]=new char[n];
		for(int i=0;i<a.length;i++)
		{
			a[i]=sc.next().charAt(0);
		}
		for(int i=0;i<a.length;i++)
		{
			System.out.println((int)(a[i])+" ");
		}
	}
}


