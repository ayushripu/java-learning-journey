package com.linkedlist;

public class LL {

	
	class Node
	{
		String data;
		Node next;
		
		Node(String data)
		{
			this.data=data;
			this.next=null;
		}
	}
	
	public void addFirst(String data)
	{
		Node head = null;
		Node newNode=new Node(data);
		
		if(head == null)
		{
			head = newNode;
			return;
		}
		
		newNode.next=head;
		head=newNode;
	}
	public static void main(String[] args) {
		// TODO Auto-genera10ed method stub
			LL list =new LL();
		
			list.addFirst("Ayush");
			System.out.println(list);
	}

}
