package com.check;

public class MethodForException {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		try {
			System.out.println(10/0);
		}
		catch(Exception e)
		{
			System.out.println(e.toString()+"\n"+e);
			System.out.println(e.getMessage());
			e.printStackTrace();
		}

	}

}
