package com.Array;

import java.util.Scanner;

public class Maximum {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		int a[]= {1,2,3,4};
		int fmax=a[0],smax=0;
		for(int i=0;i<a.length;i++)
		{
			if(a[i]>fmax)
			{
				smax=fmax;
				fmax=a[i];
			}
			else if(a[i]<fmax && a[i]>smax)
			{
				smax=a[i];
			}
		}
		System.out.println(smax);
	}

}
