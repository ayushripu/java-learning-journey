package com.For;

import java.util.Scanner;

public class DisplayDigit 
{
	public static void main(String[] args) 
	{
		Scanner sc=new Scanner(System.in);
		System.out.print("Inputed any Number :-> ");
		int n=sc.nextInt();
		while(n>0)
		{
			int r=n/100;
			n=n%100;
			System.out.println(r);
		}
	}
}