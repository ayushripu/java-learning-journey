package com.linkedlist;

public class LL {

	Node head = null;
	class Node
	{
		String data;
		Node next;
		
		Node(String data)
		{
			this.data=data;
			this.next=null;
		}
	}
	
	public void addFirst(String data)
	{
		
		Node newNode=new Node(data);
		
		if(head == null)
		{
			head = newNode;
			return;
		}
		
		newNode.next=head;
		head=newNode;
		
		System.out.println(head);
	}
	public static void main(String[] args) {
		// TODO Auto-genera10ed method stub
			LL list =new LL();
		
			list.addFirst("Ayush");
			System.out.println();
	}

}
