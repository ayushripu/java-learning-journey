package com.Array;

import java.util.Scanner;

public class max 
{
	public static void main(String[] args) 
	{
		int n,max,min;
		Scanner sc=new Scanner(System.in);
		System.out.println("Inputed How Many Number Do You Want : ");
		n=sc.nextInt();
		int a[]=new int[n];
		for(int i=0;i<a.length;i++)
		{
			a[i]=sc.nextInt();
		}
		max=min=a[0];
		for(int i=0;i<a.length;i++)
		{
			if(a[i]>=max)
			{
				max=a[i];
			}
			else if(a[i]<=min)
			{
				min=a[i];
			}
		}
		double d=(Math.random()*(max-min)+min);
		System.out.printf("Random Number is : "+"%.2f"+d);
	}
}
