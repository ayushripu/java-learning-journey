package com.For;

public class Pattern7 {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		
		for(int i=1;i<=5;i++)
		{
			for(int j=4;j>=i;j--)
			{
				System.out.print(" ");	
			}
			for(int k = 1; k<=i;k++)
			{
				System.out.print("*");
			}
			System.out.println();
		}
		for(int i=5;i>=1;i--)
		{
			for(int j=i;j<=4;j++)
			{
				System.out.print(" ");	
			}
			for(int k = i; k>=1;k--)
			{
				System.out.print("*");
			}
			System.out.println();
		}
		
		
	}
}