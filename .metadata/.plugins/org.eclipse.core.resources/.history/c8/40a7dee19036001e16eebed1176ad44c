		Scanner sc=new Scanner(System.in);
		System.out.print("Inputed any Number :-> ");
		int n=sc.nextInt();
		int r=0;
		int sum=0;
		
		int m=n;
		{
		while(n>0)
		{
			r=n%10;
			n=n/10;
			System.out.println(r);
			sum=sum+r*r*r;
			
		}
		if(sum==m)
		{
			System.out.println("Its AramStrong Number");
		}
		else
		{
			System.out.println("Not ArmStronng");
		}
		}
	}

}
