package com.stack;
import java.util.*;
public class CheckStack {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		int stack[] =new int[5];
		Scanner sc=new Scanner(System.in);
		
		for(int i=0;i<stack.length;i++)
		{
			stack[i] =sc.nextInt();
		}
		for(int i=0;i<stack.length;i++)
		{
			System.out.println(stack[i]);
		}
	}

}
