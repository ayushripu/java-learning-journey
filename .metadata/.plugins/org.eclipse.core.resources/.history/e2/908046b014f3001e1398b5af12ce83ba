package com.NestedLoop;

public class Series13 {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		for(int i=1;i<=8;i++)
		{
			for(int j=1;j<=8;j++)
			{
				if((i>j && i<j))
				{
					System.out.print(" ");
				}
				else
				{
					System.out.print("*");
				}
			}
			System.out.println();
		}
	}

}
