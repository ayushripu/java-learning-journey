package com.Array;

import java.util.Scanner;

public class max 
{
	public static void main(String[] args) 
	{
		int n;
		Scanner sc=new Scanner(System.in);
		System.out.println("Inputed How Much Number Do you Want : ");
		n=sc.nextInt();
		int a[]=new int[n];
		int max=0;
		for(int i=0;i<a.length;i++)
		{
			a[i]=sc.nextInt();
		}
		for(int i=0;i<a.length;i++)
		{
			if(max>a[i])
			{
				System.out.println(a[i]);
			}
		}
	}
}
