import java.util.Scanner;
public class Second
{
	public static void main(String[] args)
	{
		int n,max,smax,tmax;
		Scanner sc=new Scanner(System.in);
		System.out.print("Inputed Size of Array : ");
		n=sc.nextInt();
		int a[]=new int[n];
		for(int i=0;i<a.length;i++)
		{
			a[i]=sc.nextInt();
		}
		max=smax=a[0];
		for(int i=1;i<a.length;i++)
