package com.linkedlist;

class RemoveAllDuplicatesNoMap {

    // Node definition
    static class Node {
        int data;
        Node next;
        Node(int data) {
            this.data = data;
            this.next = null;
        }
    }

    // Function to remove all duplicates (both occurrences)
    public static Node removeAllDuplicates(Node head) {
        Node dummy = new Node(0); // Dummy node
        dummy.next = head;
        Node prev = dummy;
        Node current = head;

        while (current != null) {
            boolean isDuplicate = false;
            Node runner = current.next;
            Node prevRunner = current;

            while (runner != null) {
                if (runner.data == current.data) {
                    isDuplicate = true;
                    // Remove the duplicate node
                    prevRunner.next = runner.next;
                    runner = runner.next;
                } else {
                    prevRunner = runner;
                    runner = runner.next;
                }
            }

            if (isDuplicate) {
                // Remove current node as it had duplicates
                prev.next = current.next;
            } else {
                prev = current;
            }

            current = current.next;
        }

        return dummy.next;
    }

    // Helper method to print the linked list
    public static void printList(Node head) {
        Node temp = head;
        while (temp != null) {
            System.out.print(temp.data + " ");
            temp = temp.next;
        }
        System.out.println();
    }

    // Main method
    public static void main(String[] args) {
        // Creating the linked list: 1 -> 2 -> 3 -> 2 -> 4 -> 1 -> 5
        Node head = new Node(1);
        head.next = new Node(2);
        head.next.next = new Node(3);
        head.next.next.next = new Node(2);
        head.next.next.next.next = new Node(4);
        head.next.next.next.next.next = new Node(1);
        head.next.next.next.next.next.next = new Node(5);

        System.out.println("Original list:");
        printList(head);

        head = removeAllDuplicates(head);

        System.out.println("List after removing all duplicates:");
        printList(head);
    }
}
